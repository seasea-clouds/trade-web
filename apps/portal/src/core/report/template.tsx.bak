          <div className="bg-gray-50 rounded-lg p-3">
            <p className="text-xs text-gray-500 uppercase font-semibold mb-1">Top Competing Origins</p>
            <ul className="space-y-0.5">
              {result.marketIntel.topOrigins.map((o, i) => (
